DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
# Mention to include on alerts. Options:
#   @here          — notify online members
#   @everyone      — notify all members
#   <@USER_ID>     — mention a specific user
#   <@&ROLE_ID>    — mention a specific role
#   (leave empty for no mention)
DISCORD_MENTION=@here
# Google Remote Desktop direct link to this PC (tap on phone to open PWA)
REMOTE_DESKTOP_URL=https://remotedesktop.google.com/access/session/YOUR_MACHINE_ID
